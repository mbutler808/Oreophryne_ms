	journal = {BMC Bioinformatics},
	number = {6},
	pages = {153},
	title = {ASTRAL-III: polynomial time species tree reconstruction from partially resolved gene trees},
	url = {https://doi.org/10.1186/s12859-018-2129-y},
	volume = {19},
	year = {2018},
	bdsk-url-1 = {https://doi.org/10.1186/s12859-018-2129-y}}

@article{Minh:2020a,
	abstract = {{We implement two measures for quantifying genealogical concordance in phylogenomic data sets: the gene concordance factor (gCF) and the novel site concordance factor (sCF). For every branch of a reference tree, gCF is defined as the percentage of ``decisive'' gene trees containing that branch. This measure is already in wide usage, but here we introduce a package that calculates it while accounting for variable taxon coverage among gene trees. sCF is a new measure defined as the percentage of decisive sites supporting a branch in the reference tree. gCF and sCF complement classical measures of branch support in phylogenetics by providing a full description of underlying disagreement among loci and sites. An easy to use implementation and tutorial is freely available in the IQ-TREE software package (http://www.iqtree.org/doc/Concordance-Factor, last accessed May 13, 2020). }},
	author = {Minh, Bui Quang and Hahn, Matthew W and Lanfear, Robert},
	date-added = {2024-07-10 09:46:41 -1000},
	date-modified = {2024-07-10 09:46:47 -1000},
	doi = {10.1093/molbev/msaa106},
	eprint = {https://academic.oup.com/mbe/article-pdf/37/9/2727/33866528/msaa106.pdf},
	issn = {0737-4038},
	journal = {Molecular Biology and Evolution},
	month = {05},
	number = {9},
	pages = {2727-2733},
	title = {{New Methods to Calculate Concordance Factors for Phylogenomic Datasets}},
	url = {https://doi.org/10.1093/molbev/msaa106},
	volume = {37},
	year = {2020},
	bdsk-url-1 = {https://doi.org/10.1093/molbev/msaa106}}

@article{Revell:2012,
	abstract = {Summary 1. Here, I present a new, multifunctional phylogenetics package, phytools, for the R statistical computing environment. 2. The focus of the package is on methods for phylogenetic comparative biology; however, it also includes tools for tree inference, phylogeny input/output, plotting, manipulation and several other tasks. 3.I describe and tabulate the major methods implemented in phytools, and in addition provide some demonstration of its use in the form of two illustrative examples. 4.Finally, I conclude by briefly describing an active web-log that I use to document present and future developments for phytools. I also note other web resources for phylogenetics in the R computational environment.},
