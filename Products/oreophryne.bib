@article{Kraus:2013a,
	abstract = {{I describe a new species of microhylid frog of the genus Choerophryne
   from an outlying volcanic complex along the northeastern coast of Papua
   New Guinea. The new species is characterized by its marginally elongated
   snout, bright green-and-brown color pattern above, contrasting
   black-and-white color patten below, and call consisting of sparsely
   delivered clicks. Choerophryne and Albericus have been distinguished
   from each other solely on the basis of whether the alary processes of
   the premaxillae are oriented dorsally (Albericus) or anteriorly
   (Choerophryne). The new species is perfectly intermediate between these
   two states, with the alary processes oriented anteriorly at
   approximately a 45-degree angle. The distinction between these two
   genera thus seems to be based on a single character that varies
   continuously between two extremes. The horizontal orientation of the
   alary processes is clearly apomorphic. Hence, Albericus is likely to be
   a paraphyletic basal assemblage and, therefore, a junior synonym of
   Choerophryne. Nonetheless, I defer making this taxonomic change until
   explicit phylogenetic analyses are completed that include multiple
   representatives of both species. ((c) 2013 WILEY-VCH Verlag GmbH \& Co.
   KGaA, Weinheim)}},
	author = {Kraus, Fred},
	date-added = {2024-07-23 15:52:32 -1000},
	date-modified = {2024-07-23 15:52:42 -1000},
	doi = {{10.1002/zoos.201300014}},
	issn = {{1860-0743}},
	journal = {{Zoosystematics and Evolution}},
	journal-iso = {{Zoosyst. Evol.}},
	keywords = {{Amphibia; frog; Mt; Trafalgar; Oro Province}},
	keywords-plus = {{SOUTHERN HIGHLANDS PROVINCE; FROGS}},
	month = {{SEP}},
	number = {{2}},
	pages = {{283-291}},
	times-cited = {{5}},
	title = {{A New Species of Choerophryne (Anura: Microhylidae) from Papua New Guinea, with remarks on the taxonomic status of Albericus}},
	unique-id = {{ISI:000329029800009}},
	volume = {{89}},
	year = {{2013}},
	bdsk-url-1 = {https://doi.org/10.1002/zoos.201300014%7D}}

@article{Gunther:2009,
	abstract = {Abstract Based on morphological, anatomical, ecological, ethological, and molecular traits, two new genera of microhylid frogs from mainland New Guinea are described. Metamagnusia gen. n. includes two species, M. marani sp. n., the type species found in the Wondiwoi Mountains at the base of the Wandammen Peninsula (Papua Province, Indonesia), and M. slateri (Loveridge, 1955) comb. n., from eastern New Guinea (Papua New Guinea). The second new genus, Pseudocallulops gen. n., also includes two species, P. eurydactylus (Zweifel, 1972) comb. n. from the Fakfak Mountains on the Bomberai Peninsula (Papua Province, Indonesia), and P. pullifer (G{\"u}nther, 2006) comb. n., which is designated as the type species and which occurs in the Wondiwoi Mountains at the base of the Wandammen Peninsula. Both new genera belong to the group of asterophryine genera with a symphignathine state of the maxillary bones. Metamagnusia gen. n. is most closely related to the genus Asterophrys, while Pseudocallulops gen. n. forms a sister-clade of the taxa Asterophrys + Metamagnusia. The new genera are erected to recognize their differences in fundamental traits from the presently recognized genera. Another goal was to dissolve polyphyletic taxa and to avoid creation of paraphyletic taxa within the symphignathine genera of the Australopapuan microhylids. ({\copyright} 2009 WILEY-VCH Verlag GmbH \& Co. KGaA, Weinheim)},
	author = {G\"{u}nther, Rainer},
	date-added = {2024-07-23 15:50:22 -1000},
	date-modified = {2025-03-18 19:44:27 -1000},
	doi = {10.1002/zoos.200900002},
	eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/zoos.200900002},
	journal = {Zoosystematics and Evolution},
	keywords = {Asterophryinae, new genera, new species},
	number = {2},
	pages = {171-187},
	title = {Metamagnusia and Pseudocallulops, two new genera of microhylid frogs from New Guinea (Amphibia, Anura, Microhylidae)},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/zoos.200900002},
	volume = {85},
	year = {2009},
	bdsk-url-1 = {https://onlinelibrary.wiley.com/doi/abs/10.1002/zoos.200900002},
	bdsk-url-2 = {https://doi.org/10.1002/zoos.200900002}}

@article{Burton:1995,
	abstract = {{Albericus, new genus, is erected to accommodate three species removed from the genus Cophixalus Boettger 1892: Albericus darlingtoni (Loveridge) 1948, the type species; Albericus tuberculus (Richards et al.) 1992; and Albericus variegatus (van Kampen) 1923. The fifth toe being longer than the third and the M. depressor mandibulae arising mostly or entirely from the otic ramus of the squamosal and the adjacent prootic bone are apomorphic characters distinguishing Albericus from Cophixalus. The closest relative of Albericus is the monotypic genus Choerophryne with which it shares certain derived characters}},
