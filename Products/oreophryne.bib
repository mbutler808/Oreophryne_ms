	pages = {285-294},
	times-cited = {13},
	title = {A new species of frog of the genus <i>Xenorhina</i> (Anura: Microhylidae) from the north coast ranges of Papua New Guinea},
	type = {Article},
	unique-id = {WOS:000089615900002},
