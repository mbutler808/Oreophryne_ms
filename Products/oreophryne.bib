	journal = {Bulletin of the American Museum of Natural History},
	keywords = {MITOCHONDRIAL-DNA SEQUENCES; RIBOSOMAL-RNA GENES; MOLECULAR PHYLOGENETIC-RELATIONSHIPS; BOYLII SPECIES GROUP; HYPEROLIUS-VIRIDIFLAVUS COMPLEX; GEOGRAPHIC PROTEIN VARIATION; PLETHODON-CINEREUS GROUP; SOUTH-AMERICAN TOADS; BROODING HYLID FROGS; ASIAN RANID FROGS},
	pages = {8--+},
