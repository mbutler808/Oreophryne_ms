@article{Paradis:2004,
	abstract = {{Summary: Analysis of Phylogenetics and Evolution (APE) is a package
   written in the R language for use in molecular evolution and
   phylogenetics. APE provides both utility functions for reading and
   writing data and manipulating phylogenetic trees, as well as several
   advanced methods for phylogenetic and evolutionary analysis (e.g.
   comparative and population genetic methods). APE takes advantage of the
   many R functions for statistics and graphics, and also provides a
   flexible framework for developing and implementing further statistical
